{
  "name": "@nozomiishii/prettier-config",
  "version": "0.8.0",
  "description": "Nozomi's Recommended Prettier config",
  "keywords": [
    "prettier",
    "config"
  ],
  "homepage": "https://github.com/nozomiishii/configs/blob/main/packages/prettier-config/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/nozomiishii/configs.git",
    "directory": "packages/prettier-config"
  },
  "license": "MIT",
  "author": "Nozomi Ishii",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nozo-prettier-init": "./dist/init.js"
  },
  "files": [
    "dist",
    "starter.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --sourcemap",
    "prepublishOnly": "pnpm run build",
    "tsc": "tsc"
  },
  "dependencies": {
    "prettier": "3.8.3",
    "prettier-plugin-packagejson": "3.0.2"
  },
  "devDependencies": {
    "@nozomiishii/tsconfig": "workspace:*",
    "@types/node": "24.12.2",
    "tsdown": "0.21.10",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.33.2",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
