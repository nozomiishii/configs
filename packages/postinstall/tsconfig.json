{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@nozomiishii/tsconfig/tsconfig.json",

  "compilerOptions": {
    // ----------------------------------------------------------------
    // Transpiling
    // ----------------------------------------------------------------
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "noEmit": true,

    // TypeScript 6.0で非推奨化されたオプションの警告を抑制
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
