{
  "name": "@nozomiishii/postinstall",
  "version": "0.1.0",
  "description": "Nozomi's Recommended postinstall scripts",
  "keywords": [
    "postinstall",
    "scripts"
  ],
  "homepage": "https://github.com/nozomiishii/configs/blob/main/packages/postinstall/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/nozomiishii/configs.git",
    "directory": "packages/postinstall"
  },
  "license": "MIT",
  "author": "Nozomi Ishii",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "postinstall": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --sourcemap",
    "link": "pnpm link --global",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "tsc": "tsc"
  },
  "dependencies": {
    "figlet": "1.11.0",
    "zx": "8.8.5"
  },
  "devDependencies": {
    "@nozomiishii/tsconfig": "workspace:*",
    "@types/figlet": "1.7.0",
    "@types/node": "24.12.2",
    "tsdown": "0.21.10",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@10.33.2",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
