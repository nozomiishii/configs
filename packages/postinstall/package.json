{
  "name": "@nozomiishii/postinstall",
  "version": "1.8.0",
  "description": "Nozomi's Recommended postinstall scripts",
  "keywords": [
    "postinstall",
    "scripts"
  ],
  "homepage": "https://github.com/nozomiishii/configs/blob/main/packages/postinstall/README.md",
  "bugs": {
    "url": "https://github.com/nozomiishii/configs/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nozomiishii/configs.git",
    "directory": "packages/postinstall"
  },
  "license": "MIT",
  "author": "Nozomi Ishii",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./init": "./dist/init/index.js"
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "nozo-postinstall-init": "./bin/nozo-postinstall-init.js",
    "postinstall": "./bin/postinstall.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --sourcemap",
