    "tsc": "tsc"
  },
  "dependencies": {
    "figlet": "1.11.0",
    "zx": "8.8.5"
  },
  "devDependencies": {
    "@nozomiishii/tsconfig": "workspace:*",
    "@types/figlet": "1.7.0",
    "@types/node": "24.12.2",
    "tsdown": "0.22.2",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "packageManager": "pnpm@11.7.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
