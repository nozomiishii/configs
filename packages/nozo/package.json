{
  "name": "nozo",
  "version": "1.0.1",
  "description": "nozo shared configs CLI",
  "keywords": [
    "cli",
    "config"
  ],
  "homepage": "https://github.com/nozomiishii/configs/blob/main/packages/nozo/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/nozomiishii/configs.git",
    "directory": "packages/nozo"
  },
  "license": "MIT",
  "author": "Nozomi Ishii",
  "type": "module",
  "bin": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --sourcemap",
    "lint": "eslint --max-warnings=0 .",
    "lint:fix": "eslint --max-warnings=0 . --fix",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "tsc": "tsc"
  },
  "dependencies": {
    "@clack/prompts": "1.3.0",
    "@nozomiishii/commitlint-config": "workspace:*",
    "@nozomiishii/eslint-config": "workspace:*",
    "@nozomiishii/lefthook-config": "workspace:*",
    "@nozomiishii/postinstall": "workspace:*",
    "@nozomiishii/prettier-config": "workspace:*",
    "citty": "0.2.2",
    "consola": "3.4.2",
    "package-manager-detector": "1.6.0",
    "which": "7.0.0"
  },
  "devDependencies": {
    "@nozomiishii/tsconfig": "workspace:*",
    "@types/node": "24.12.2",
    "@types/which": "3.0.4",
    "eslint": "10.3.0",
    "tsdown": "0.22.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
