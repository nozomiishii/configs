{
  "name": "@nozomiishii/eslint-config",
  "version": "1.7.0",
  "description": "Nozomi's Recommended eslint config",
  "keywords": [
    "eslint",
    "lint",
    "config"
  ],
  "homepage": "https://github.com/nozomiishii/configs/blob/main/packages/eslint-config/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/nozomiishii/configs.git",
    "directory": "packages/eslint-config"
  },
  "license": "MIT",
  "author": "Nozomi Ishii",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./init": "./dist/init/index.js"
  },
  "main": "index.ts",
  "bin": {
    "nozo-eslint-init": "./bin/nozo-eslint-init.js"
  },
  "files": [
    "bin",
    "dist",
    "index.ts",
    "presets",
    "rules",
    "starters",
    "types",
    "utils",
    "eslint-typegen.d.ts",
    "README.md",
    "README.ja.md"
  ],
  "scripts": {
    "build": "tsdown",
    "check:ts": "tsc",
    "dev": "pnpm typegen && eslint --inspect-config",
    "eslint": "eslint --max-warnings=0",
    "link": "pnpm link --global",
    "lint": "pnpm eslint .",
    "lint:fix": "pnpm eslint . --fix",
    "prepare": "pnpm run typegen",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typegen": "node --import @swc-node/register/esm-register scripts/typegen.ts"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@eslint-react/eslint-plugin": "5.8.17",
    "@eslint/config-inspector": "3.0.4",
    "@eslint/js": "10.0.1",
    "@next/eslint-plugin-next": "16.2.9",
    "@stylistic/eslint-plugin": "5.10.0",
    "@swc-node/register": "1.11.1",
    "@types/node": "24.12.2",
    "@vitest/eslint-plugin": "1.6.20",
    "eslint-config-flat-gitignore": "2.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-better-tailwindcss": "4.6.0",
    "eslint-plugin-de-morgan": "2.1.2",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsdoc": "63.0.2",
    "eslint-plugin-jsonc": "3.2.0",
    "eslint-plugin-jsx-a11y-x": "0.2.0",
    "eslint-plugin-n": "18.1.0",
    "eslint-plugin-package-json": "1.3.0",
    "eslint-plugin-perfectionist": "5.9.0",
    "eslint-plugin-playwright": "2.10.4",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-storybook": "10.4.3",
    "eslint-plugin-tsdoc": "0.5.2",
    "eslint-plugin-unicorn": "65.0.1",
    "eslint-typegen": "2.3.1",
    "globals": "17.6.0",
    "jsonc-eslint-parser": "3.1.0",
    "tailwindcss": "4.3.0",
    "typescript-eslint": "8.61.0"
  },
  "devDependencies": {
    "eslint": "10.4.1",
    "tsdown": "0.22.2",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "eslint": "10.4.1",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
