{
  "name": "@nozomiishii/eslint-config",
  "version": "0.6.11",
  "description": "Nozomi's Recommended eslint config",
  "keywords": [
    "eslint",
    "lint",
    "config"
  ],
  "homepage": "https://github.com/nozomiishii/configs/blob/main/packages/eslint-config/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/nozomiishii/configs.git",
    "directory": "packages/eslint-config"
  },
  "license": "MIT",
  "author": "Nozomi Ishii",
  "type": "module",
  "main": "eslint.config.ts",
  "bin": "bin/cli.sh",
  "scripts": {
    "build": "pnpx @eslint/config-inspector build",
    "check:ts": "tsc",
    "dev": "pnpm typegen && eslint --inspect-config",
    "eslint": "eslint --max-warnings=0",
    "postinstall": "pnpm typegen",
    "link": "pnpm link --global",
    "lint": "pnpm eslint .",
    "lint:fix": "pnpm eslint . --fix",
    "prepublishOnly": "pnpm run build",
    "start": "pnpx serve .eslint-config-inspector",
    "typegen": "node --import @swc-node/register/esm-register scripts/typegen.ts"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
    "@eslint-react/eslint-plugin": "2.13.0",
    "@eslint/config-inspector": "1.5.0",
    "@eslint/js": "10.0.1",
    "@next/eslint-plugin-next": "16.1.6",
    "@stylistic/eslint-plugin": "5.10.0",
    "@swc-node/register": "1.11.1",
    "@types/node": "24.12.0",
    "@vitest/eslint-plugin": "1.6.10",
    "eslint": "10.0.3",
    "eslint-config-flat-gitignore": "2.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-better-tailwindcss": "4.3.2",
    "eslint-plugin-de-morgan": "2.1.1",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-plugin-jsdoc": "62.7.1",
    "eslint-plugin-jsonc": "3.1.1",
    "eslint-plugin-jsx-a11y-x": "0.1.1",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-package-json": "0.89.4",
    "eslint-plugin-perfectionist": "5.6.0",
    "eslint-plugin-playwright": "2.9.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-storybook": "10.2.17",
    "eslint-plugin-tsdoc": "0.5.2",
    "eslint-plugin-unicorn": "63.0.0",
    "eslint-typegen": "2.3.1",
    "globals": "17.4.0",
    "jsonc-eslint-parser": "3.1.0",
    "tailwindcss": "4.2.1",
    "typescript-eslint": "8.56.1"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "eslint": "^10.0.3",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
