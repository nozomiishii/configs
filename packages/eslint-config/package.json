{
  "name": "@nozomiishii/eslint-config",
  "version": "0.8.1",
  "description": "Nozomi's Recommended eslint config",
  "keywords": [
    "eslint",
    "lint",
    "config"
  ],
  "homepage": "https://github.com/nozomiishii/configs/blob/main/packages/eslint-config/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/nozomiishii/configs.git",
    "directory": "packages/eslint-config"
  },
  "license": "MIT",
  "author": "Nozomi Ishii",
  "type": "module",
  "main": "eslint.config.ts",
  "bin": {
    "nozo-eslint-init": "./dist/init.js"
  },
  "files": [
    "dist",
    "rules",
    "utils",
    "eslint-typegen.d.ts",
    "eslint.config.ts",
    "starter.ts",
    "README.md",
    "README.ja.md"
  ],
  "scripts": {
    "build": "tsdown",
    "build:inspector": "pnpx @eslint/config-inspector build",
    "check:ts": "tsc",
    "dev": "pnpm typegen && eslint --inspect-config",
    "eslint": "eslint --max-warnings=0",
    "link": "pnpm link --global",
    "lint": "pnpm eslint .",
    "lint:fix": "pnpm eslint . --fix",
    "prepare": "pnpm run typegen",
    "prepublishOnly": "pnpm run build && pnpm run build:inspector",
    "start": "pnpx serve .eslint-config-inspector",
    "test": "vitest run",
    "typegen": "node --import @swc-node/register/esm-register scripts/typegen.ts"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
    "@eslint-react/eslint-plugin": "5.6.4",
    "@eslint/config-inspector": "2.0.0",
    "@eslint/js": "10.0.1",
    "@next/eslint-plugin-next": "16.2.4",
    "@stylistic/eslint-plugin": "5.10.0",
    "@swc-node/register": "1.11.1",
    "@types/node": "24.12.2",
    "@vitest/eslint-plugin": "1.6.16",
    "eslint-config-flat-gitignore": "2.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-better-tailwindcss": "4.5.0",
    "eslint-plugin-de-morgan": "2.1.1",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-jsonc": "3.1.2",
    "eslint-plugin-jsx-a11y-x": "0.1.1",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-package-json": "0.91.2",
    "eslint-plugin-perfectionist": "5.9.0",
    "eslint-plugin-playwright": "2.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-storybook": "10.3.6",
    "eslint-plugin-tsdoc": "0.5.2",
    "eslint-plugin-unicorn": "64.0.0",
    "eslint-typegen": "2.3.1",
    "globals": "17.5.0",
    "jsonc-eslint-parser": "3.1.0",
    "tailwindcss": "4.2.4",
    "typescript-eslint": "8.59.1"
  },
  "devDependencies": {
    "eslint": "10.2.1",
    "tsdown": "0.21.10",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "eslint": "10.2.1",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
